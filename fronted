<!DOCTYPE html>
<html>
<head>
    <title>AWS Three Tier App</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <h1>🚀 AWS Three Tier App Running</h1>
    <button onclick="callAPI()">Call Backend</button>
    
    <p id="result"></p>

    <script src="app.js"></script>
</body>
</html>

//css
body {
    text-align: center;
    font-family: Arial, sans-serif;
    margin-top: 50px;
}

button {
    padding: 10px 20px;
    font-size: 16px;
    cursor: pointer;
}
// js
function callAPI() {
    fetch("http://localhost:5000")
    .then(response => response.json())
    .then(data => {
        document.getElementById("result").innerText = data.message;
    })
    .catch(error => {
        document.getElementById("result").innerText = "Error connecting to backend";
    });
}